{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agenteia://contracts/LayoutSpec",
  "type": "object",
  "properties": {
    "canvas": {
      "type": "object",
      "properties": { "w": { "type": "integer" }, "h": { "type": "integer" } }
    },
    "regions": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "x": { "type": "integer" },
          "y": { "type": "integer" },
          "w": { "type": "integer" },
          "h": { "type": "integer" },
          "pitch": { "type": "integer" },
          "radius": { "type": "integer" }
        }
      }
    },
    "hitZones": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "x": { "type": "integer" },
          "y": { "type": "integer" },
          "w": { "type": "integer" },
          "h": { "type": "integer" }
        }
      }
    }
  }
}
