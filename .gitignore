# Secrets — never commit (WiFi credentials, Home Assistant token, server URL)
firmware/agente-ia/secrets.h
server/secrets.local.ps1
server/.env

# Persistent agent memory (personal: the human's name, facts, mood)
server/agent_state.json

# Generated SPIFFS image (build it with upload_spiffs.ps1 from data/)
firmware/agente-ia/spiffs.bin

# Python
server/.venv/
server/__pycache__/
*.pyc

# Downloaded/large runtime assets
server/voices/

# Local recordings / scratch / logs
server/debug_audio/
tmp/
*.log
