# Copy this file to secrets.local.ps1 and fill in your values.
# secrets.local.ps1 is gitignored — never commit real tokens.
# start.ps1 sources it automatically if present.

# Home Assistant (home-automation integration). Leave unset to disable HA.
$env:HA_URL = "http://homeassistant.local:8123"
$env:HA_TOKEN = "your-long-lived-access-token"

# ── Voz RVC local (Applio VoiceConverter) ─────────────────────────────
# Pipeline: texto → edge-tts (guia) → RVC (.pth + .index) → WAV
# NO requiere bender_server ni :7860 — todo dentro de agenteIA/server.
#
# APPLIO_DIR = carpeta raiz donde instalaste Applio (contiene rvc/infer/)
# APPLIO_PYTHON = python del venv de Applio (torch + faiss ya incluidos)
# RVC_MODEL_PATH = inference .pth (~50 MB), NO el checkpoint G_XXXXX.pth (~430 MB)
# RVC_INDEX_PATH = .index FAISS del personaje

$env:ENABLE_TTS_RVC = "1"
$env:APPLIO_DIR = "H:\ruta\a\Applio"
$env:APPLIO_PYTHON = "H:\ruta\a\Applio\env\python.exe"
$env:RVC_MODEL_PATH = "H:\modelos_rvc\personaje\personaje_500e_2500s.pth"
$env:RVC_INDEX_PATH = "H:\modelos_rvc\personaje\personaje.index"

# Guia TTS (edge = Microsoft neural, gratis, sin API key)
$env:TTS_RVC_GUIDE = "edge"
$env:TTS_RVC_EDGE_VOICE = "es-MX-JorgeNeural"
$env:TTS_SPEED_PERCENT = "5"

# Parametros RVC (ver doc IMPLEM — rmvpe + contentvec son los habituales)
$env:RVC_F0_METHOD = "rmvpe"
$env:TTS_RVC_F0_UP_KEY = "0"
$env:TTS_RVC_INDEX_RATE = "0.75"
$env:TTS_RVC_PROTECT = "0.33"

# Cantar (Bark + RVC). Solo si ENABLE_SINGING=1 en start.ps1:
# $env:ENABLE_SINGING = "1"

# ── YouTube Music (panel admin → pestaña Música) ───────────────────
# API oficial Google (búsqueda). Crear en Google Cloud Console → YouTube Data API v3.
# $env:YOUTUBE_API_KEY = "AIza..."
# Audio: pytubefix (rápido) + yt-dlp como respaldo. Requiere ffmpeg en PATH.
# Opcional: cookies Netscape para ytmusicapi enriquecido.
# $env:YTMUSIC_COOKIES_PATH = "H:\ruta\cookies.txt"
